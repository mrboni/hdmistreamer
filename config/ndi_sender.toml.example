ndi_name = "RPi5-X1300"
ndi_fourcc = "RGBX"
video_device = "/dev/video0"
width = 1920
height = 1080
fps_num = 25
fps_den = 1
sample_timeout_sec = 0.5
no_frame_restart_sec = 3.0
capture_backend = "gstreamer"
ndi_send_async = true
ndi_clock_video = true
ffmpeg_path = "ffmpeg"
ffmpeg_loglevel = "error"
ffmpeg_input_format = "rgb24"
ffmpeg_pix_fmt = "rgb0"
ffmpeg_vsync = 0
ffmpeg_threads = 4
ffmpeg_thread_queue_size = 512
appsink_max_buffers = 2
gst_io_mode = "mmap"
gst_convert_threads = 4
gst_input_format = "RGB"
gst_output_format = "BGRx"
log_level = "INFO"
