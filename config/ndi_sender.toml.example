ndi_name = "RPi5-X1300"
ndi_fourcc = "UYVY"
video_device = "/dev/video0"
width = 1920
height = 1080
fps_num = 25
fps_den = 1
sample_timeout_sec = 0.5
no_frame_restart_sec = 3.0
capture_backend = "gstreamer"
ndi_send_async = true
ndi_safe_copy = true
ndi_async_safe_copy = true
ndi_clock_video = true
ffmpeg_path = "ffmpeg"
ffmpeg_loglevel = "error"
ffmpeg_input_format = "uyvy422"
ffmpeg_pix_fmt = "uyvy422"
ffmpeg_vsync = 0
ffmpeg_threads = 4
ffmpeg_thread_queue_size = 512
appsink_max_buffers = 2
gst_io_mode = "mmap"
gst_convert_threads = 4
gst_input_format = "UYVY"
gst_output_format = "UYVY"
# Optional full source stage override for custom capture graphs (e.g. USB MJPEG decode):
# gst_source_pipeline = "v4l2src device=/dev/video2 io-mode=mmap do-timestamp=true ! image/jpeg,width=1920,height=1080,framerate=60/1 ! jpegdec ! videoconvert ! video/x-raw,format=UYVY,width=1920,height=1080,framerate=60/1"
gst_source_pipeline = ""
gst_use_leaky_queue = false
gst_queue_max_buffers = 1
drop_stale_ms = 0.0
log_level = "INFO"
