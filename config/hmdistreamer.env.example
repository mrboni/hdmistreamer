# Capture bring-up configuration
# Input source selector:
# - hdmi-csi: run HDMI/EDID/media-graph bring-up (default, X1300 path)
# - usb-uvc: skip HDMI bring-up and prepare USB video node only
# - none: skip source preparation entirely
HMDI_INPUT_KIND=hdmi-csi
HMDI_MODE=1080p-auto
V4L_SUBDEV=/dev/v4l-subdev2
VIDEO_DEV=/dev/video0
MEDIA_DEV=/dev/media0
EDID_DIR=/etc/hmdistreamer/edid
RUNTIME_ENV_FILE=/run/hmdistreamer/video.env
# Optional override for a fixed EDID path (wins over HMDI_MODE profile EDID).
# Keeping this stable avoids source capability/identity changes during mode switches.
# EDID_FILE=/etc/hmdistreamer/edid/1080p60edid
# Optional custom timing overrides (default from HMDI_MODE profile).
# Leave FPS/pixelclock unset to allow auto lock within selected resolution.
# EXPECTED_WIDTH=1920
# EXPECTED_HEIGHT=1080
# EXPECTED_PIXELCLOCK=148500000
# EXPECTED_FPS_NUM=60
# EXPECTED_FPS_DEN=1
HDMI_LOCK_RETRIES=15
HDMI_LOCK_DELAY_SEC=2
VALIDATE_STREAM=0
VALIDATE_FRAME_COUNT=60
# Native capture format defaults (avoid unnecessary colorspace conversion).
HMDI_MEDIA_BUS_FMT=UYVY8_1X16
HMDI_MEDIA_FIELD=none
HMDI_MEDIA_COLORSPACE=srgb
HMDI_VIDEO_PIXFMT=UYVY
# Optional USB source prep controls (used only when HMDI_INPUT_KIND=usb-uvc):
# HMDI_USB_SET_FORMAT=1
# HMDI_USB_WIDTH=1920
# HMDI_USB_HEIGHT=1080
# HMDI_USB_PIXFMT=UYVY
# HMDI_USB_VALIDATE_STREAM=0

# NDI sender overrides
HMDI_NDI_NAME=RPi5-X1300
HMDI_VIDEO_DEVICE=/dev/video0
# Usually auto-populated by /run/hmdistreamer/video.env.
# Uncomment only when you intentionally want to force sender dimensions.
# HMDI_WIDTH=1920
# HMDI_HEIGHT=1080
# HMDI_FPS_NUM=60
# HMDI_FPS_DEN=1
HMDI_SAMPLE_TIMEOUT_SEC=0.5
HMDI_NO_FRAME_RESTART_SEC=3.0
HMDI_CAPTURE_BACKEND=gstreamer
HMDI_NDI_SEND_ASYNC=1
HMDI_NDI_SAFE_COPY=1
HMDI_NDI_ASYNC_SAFE_COPY=1
HMDI_NDI_CLOCK_VIDEO=1
HMDI_NDI_FOURCC=UYVY
HMDI_FFMPEG_PATH=ffmpeg
HMDI_FFMPEG_LOGLEVEL=error
HMDI_FFMPEG_INPUT_FORMAT=uyvy422
HMDI_FFMPEG_PIX_FMT=uyvy422
HMDI_FFMPEG_VSYNC=0
HMDI_FFMPEG_THREADS=4
HMDI_FFMPEG_THREAD_QUEUE_SIZE=512
HMDI_APPSINK_MAX_BUFFERS=2
HMDI_GST_IO_MODE=mmap
HMDI_GST_CONVERT_THREADS=4
HMDI_GST_INPUT_FORMAT=UYVY
HMDI_GST_OUTPUT_FORMAT=UYVY
# Optional full GStreamer source-stage override. Useful for USB cameras that
# need decode/transform before appsink (for example MJPEG webcams).
# HMDI_GST_SOURCE_PIPELINE=v4l2src device=/dev/video2 io-mode=mmap do-timestamp=true ! image/jpeg,width=1920,height=1080,framerate=60/1 ! jpegdec ! videoconvert ! video/x-raw,format=UYVY,width=1920,height=1080,framerate=60/1
# Optional aggressive latency controls (can increase visible frame drops/judder):
# HMDI_GST_USE_LEAKY_QUEUE=1
# HMDI_GST_QUEUE_MAX_BUFFERS=1
# HMDI_DROP_STALE_MS=120
HMDI_LOG_LEVEL=INFO
