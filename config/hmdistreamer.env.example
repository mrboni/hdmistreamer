# Capture bring-up configuration
HMDI_MODE=1080p25
V4L_SUBDEV=/dev/v4l-subdev2
VIDEO_DEV=/dev/video0
MEDIA_DEV=/dev/media0
EDID_DIR=/etc/hmdistreamer/edid
RUNTIME_ENV_FILE=/run/hmdistreamer/video.env
# Optional override for custom EDID path (wins over HMDI_MODE).
# EDID_FILE=/etc/hmdistreamer/edid/1080p25edid
# Optional custom timing overrides (default from HMDI_MODE profile).
# EXPECTED_WIDTH=1920
# EXPECTED_HEIGHT=1080
# EXPECTED_PIXELCLOCK=74250000
# EXPECTED_FPS_NUM=25
# EXPECTED_FPS_DEN=1
HDMI_LOCK_RETRIES=15
HDMI_LOCK_DELAY_SEC=2
VALIDATE_STREAM=0
VALIDATE_FRAME_COUNT=60

# NDI sender overrides
HMDI_NDI_NAME=RPi5-X1300
HMDI_VIDEO_DEVICE=/dev/video0
# Usually auto-populated by /run/hmdistreamer/video.env.
# Uncomment only when you intentionally want to force sender dimensions.
# HMDI_WIDTH=1920
# HMDI_HEIGHT=1080
# HMDI_FPS_NUM=25
# HMDI_FPS_DEN=1
HMDI_SAMPLE_TIMEOUT_SEC=0.5
HMDI_NO_FRAME_RESTART_SEC=3.0
HMDI_CAPTURE_BACKEND=gstreamer
HMDI_NDI_SEND_ASYNC=1
HMDI_NDI_FOURCC=RGBX
HMDI_FFMPEG_PATH=ffmpeg
HMDI_FFMPEG_LOGLEVEL=error
HMDI_FFMPEG_INPUT_FORMAT=rgb24
HMDI_FFMPEG_PIX_FMT=rgb0
HMDI_FFMPEG_VSYNC=0
HMDI_FFMPEG_THREADS=4
HMDI_FFMPEG_THREAD_QUEUE_SIZE=512
HMDI_APPSINK_MAX_BUFFERS=2
HMDI_GST_IO_MODE=mmap
HMDI_GST_CONVERT_THREADS=4
HMDI_GST_INPUT_FORMAT=RGB
HMDI_GST_OUTPUT_FORMAT=BGRx
HMDI_LOG_LEVEL=INFO
